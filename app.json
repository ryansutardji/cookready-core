{
  "expo": {
    "name": "CookReady",
    "slug": "cookready",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cookready",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#be4b1b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cookready.app",
      "buildNumber": "1"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.cookready.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#be4b1b"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18e6b991-20a9-42ec-9612-c3ba6321961f"
      }
    }
  }
}
